# MySQL 数据库密码（强密码）
MYSQL_ROOT_PASSWORD=ChangeMe_ToStrongPassword_2024!

# 数据库名
MYSQL_DATABASE=xflow_db

# JWT 签名密钥（使用 openssl rand -base64 32 生成）
# 必须至少 32 个字符
JWT_SECRET=Replace_This_With_A_Strong_Random_Secret_Key_At_Least_32_Chars_Long
