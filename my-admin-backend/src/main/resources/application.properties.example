# 后端敏感配置 - 包含数据库密码、JWT 密钥等
# 真实配置文件 application.properties 已在 .gitignore 中排除
# 请复制此文件为 application.properties 并填写实际配置

spring.application.name=my-admin-backend

# ============== 数据库配置 ==============
# 请修改为你的 MySQL 连接信息
spring.datasource.url=jdbc:mysql://localhost:3306/my_xflow_db?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
spring.datasource.username=your_username
spring.datasource.password=your_password
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ============== JPA 配置 ==============
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# ============== JWT 配置 ==============
# 密钥至少 32 个字符，建议使用随机生成的强密钥
# 生成示例：openssl rand -base64 32
jwt.secret=please-replace-this-with-a-secure-random-key-at-least-32-chars
jwt.expiration=86400000

# ============== 服务端口 ==============
server.port=8080
